{
  "name": "jigsaw",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently 'bun run dev:api' 'bun run dev:ui'",
    "dev:api": "bun --watch server.js",
    "dev:ui": "vite",
    "start": "PORT=80 bun server.js",
    "test": "bunx playwright test",
    "test:mobile": "bunx playwright test --project=mobile-iphone --project=mobile-small --project=landscape-mobile"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^9",
    "vite": "^6"
  }
}
